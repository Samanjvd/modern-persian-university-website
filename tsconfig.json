{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",

    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    "baseUrl": ".",
    "ignoreDeprecations": "6.0",

    "paths": {
      "@/*": ["src/*"]
    },

    "types": ["node"],
    "allowJs": true,
    "incremental": true
  },

  "include": ["next-env.d.ts", "src", "pages", "next.config.mjs"],

  "exclude": ["node_modules"]
}
